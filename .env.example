# Copy to `.env` and fill locally. Do not commit `.env`.

# Required for any LLM / embeddings / Qdrant step (no defaults in code).
OPENAI_API_KEY=
OPENAI_BASE_URL=
EMBEDDINGS_BASE_URL=
QDRANT_URL=

# Langfuse (LLM tracing). Leave LANGFUSE_ENABLE empty/false to disable.
LANGFUSE_ENABLE=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# MLflow tracking URI for eval runs (experiment name comes from the adapter).
MLFLOW_TRACKING_URI=

# PostgreSQL for `python -m research.datasets.build` (optional for reading code).
DB_HOST=
DB_NAME=
DB_PORT=
DB_LOGIN=
DB_PASSWORD=
