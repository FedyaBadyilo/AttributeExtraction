{
  "info": {
    "name": "Attribute Extractor Backend",
    "description": "Pilot API collection for local backend smoke testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "task_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Object Types",
      "item": [
        {
          "name": "List object types",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/object-types"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('task_id', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pilot task {{$timestamp}}\",\n  \"object_type\": \"heat_exchangers\"\n}"
            },
            "url": "{{base_url}}/tasks"
          }
        },
        {
          "name": "List tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tasks?limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Get task",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tasks/{{task_id}}"
          }
        },
        {
          "name": "Update task",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pilot task renamed {{$timestamp}}\"\n}"
            },
            "url": "{{base_url}}/tasks/{{task_id}}"
          }
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tasks/{{task_id}}"
          }
        }
      ]
    },
    {
      "name": "Task Files",
      "item": [
        {
          "name": "Upload registry",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{base_url}}/tasks/{{task_id}}/registry"
          }
        },
        {
          "name": "Upload documents ZIP",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{base_url}}/tasks/{{task_id}}/documents"
          }
        },
        {
          "name": "Delete documents ZIP",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tasks/{{task_id}}/documents"
          }
        },
        {
          "name": "Upload ground truth",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{base_url}}/tasks/{{task_id}}/ground-truth"
          }
        },
        {
          "name": "Delete ground truth",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tasks/{{task_id}}/ground-truth"
          }
        }
      ]
    },
    {
      "name": "Validation",
      "item": [
        {
          "name": "Validate task sources",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tasks/{{task_id}}/validate"
          }
        }
      ]
    },
    {
      "name": "Processing",
      "item": [
        {
          "name": "Start processing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"from_start\"\n}"
            },
            "url": "{{base_url}}/tasks/{{task_id}}/process"
          }
        },
        {
          "name": "Download result",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tasks/{{task_id}}/result"
          }
        }
      ]
    }
  ]
}
